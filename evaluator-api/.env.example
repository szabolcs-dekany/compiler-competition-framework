# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/evaluator?schema=public"

# Test Cases
TEST_CASES_DIR="test-cases"

# Redis
REDIS_HOST="localhost"
REDIS_PORT=6379

# Garage (S3-compatible storage)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="GK00000000deadbeefcafe0001"
S3_SECRET_KEY="a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456"
S3_BUCKET="evaluator-artifacts"
S3_REGION="garage"

# Worker Configuration
WORKER_CONCURRENCY_BUILD=2
WORKER_CONCURRENCY_EVALUATE=4
WORKER_CONCURRENCY_CLEANUP=1

# Docker Settings
DOCKER_TIMEOUT_MS=30000
DOCKER_MAX_MEMORY_MB=256
DOCKER_SOCKET_PATH=/var/run/docker.sock
# For Podman, use:
# DOCKER_SOCKET_PATH=unix:///run/podman/podman.sock