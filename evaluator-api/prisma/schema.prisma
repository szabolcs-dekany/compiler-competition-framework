generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  submissions  Submission[]
  sourceFiles  SourceFile[]
  dockerfile   Dockerfile?
}

model Dockerfile {
  id            String              @id @default(cuid())
  teamId        String              @unique
  team          Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  originalName  String
  s3Key         String
  size          Int
  checksum      String
  version       Int                 @default(1)
  uploadedAt    DateTime            @default(now())
  imageName     String?
  versions      DockerfileVersion[]

  @@index([teamId])
}

model DockerfileVersion {
  id               String      @id @default(cuid())
  dockerfileId     String
  dockerfile       Dockerfile  @relation(fields: [dockerfileId], references: [id], onDelete: Cascade)
  version          Int
  s3Key            String
  size             Int
  checksum         String
  uploadedAt       DateTime    @default(now())
  buildStatus      BuildStatus @default(PENDING)
  buildLogS3Key    String?
  buildStartedAt   DateTime?
  buildCompletedAt DateTime?
  buildError       String?

  @@unique([dockerfileId, version])
  @@index([dockerfileId])
}

enum BuildStatus {
  PENDING
  BUILDING
  SUCCESS
  FAILED
}

model SourceFile {
  id                       String              @id @default(cuid())
  teamId                   String
  team                     Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  testCaseId               String
  originalName             String
  extension                String
  s3Key                    String
  size                     Int
  checksum                 String
  version                  Int                 @default(1)
  uploadedAt               DateTime            @default(now())
  versions                 SourceFileVersion[]

  @@unique([teamId, testCaseId])
  @@index([teamId])
}

model SourceFileVersion {
  id                       String      @id @default(cuid())
  sourceFileId             String
  sourceFile               SourceFile  @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  version                  Int
  s3Key                    String
  size                     Int
  checksum                 String
  uploadedAt               DateTime    @default(now())
  compilations             Compilation[]

  @@unique([sourceFileId, version])
  @@index([sourceFileId])
}

model Compilation {
  id                  String            @id @default(cuid())
  sourceFileVersionId String
  sourceFileVersion   SourceFileVersion @relation(fields: [sourceFileVersionId], references: [id], onDelete: Cascade)
  submissionId        String
  submission          Submission        @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  status              CompilationStatus @default(PENDING)
  s3Key               String?
  startedAt           DateTime?
  completedAt         DateTime?
  errorMessage        String?
  createdAt           DateTime          @default(now())

  @@unique([sourceFileVersionId, submissionId])
  @@index([sourceFileVersionId])
  @@index([submissionId])
}

model Submission {
  id                 String           @id @default(cuid())
  teamId             String
  team               Team             @relation(fields: [teamId], references: [id])
  version            Int              @default(1)
  originalName       String
  extension          String
  compilerPath       String?
  status             SubmissionStatus @default(PENDING)
  submittedAt        DateTime         @default(now())
  testRuns           TestRun[]
  compilations       Compilation[]
  totalScore         Int              @default(0)
  compileStatus      CompileStatus    @default(PENDING)
  compileLogS3Key    String?
  compileStartedAt   DateTime?
  compileCompletedAt DateTime?
  compileError       String?

  @@unique([teamId, version])
}

model TestRun {
  id               String          @id @default(cuid())
  submissionId     String
  submission       Submission      @relation(fields: [submissionId], references: [id])
  testCaseId       String
  status           TestRunStatus   @default(PENDING)
  compileSuccess   Boolean?
  compileTimeMs    Int?
  runSuccess       Boolean?
  runTimeMs        Int?
  actualStdout     String?
  actualStderr     String?
  expectedStdout   String?
  expectedExitCode Int?
  actualExitCode   Int?
  pointsEarned     Int             @default(0)
  bonusEarned      Int             @default(0)
  errorMessage     String?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?

  @@index([submissionId])
  @@index([testCaseId])
}

enum SubmissionStatus {
  PENDING
  BUILDING
  READY
  EVALUATING
  COMPLETED
  FAILED
}

enum CompileStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

enum SourceFileCompileStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

enum CompilationStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
}

enum TestRunStatus {
  PENDING
  COMPILING
  RUNNING
  PASSED
  FAILED
  TIMEOUT
  ERROR
}
