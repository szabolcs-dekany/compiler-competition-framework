generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id           String        @id @default(cuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  submissions  Submission[]
  sourceFiles  SourceFile[]
}

model SourceFile {
  id            String              @id @default(cuid())
  teamId        String
  team          Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  testCaseId    String
  originalName  String
  extension     String
  s3Key         String
  size          Int
  checksum      String
  version       Int                 @default(1)
  uploadedAt    DateTime            @default(now())
  versions      SourceFileVersion[]

  @@unique([teamId, testCaseId])
  @@index([teamId])
}

model SourceFileVersion {
  id           String      @id @default(cuid())
  sourceFileId String
  sourceFile   SourceFile  @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)
  version      Int
  s3Key        String
  size         Int
  checksum     String
  uploadedAt   DateTime    @default(now())

  @@unique([sourceFileId, version])
  @@index([sourceFileId])
}

model Submission {
  id           String           @id @default(cuid())
  teamId       String
  team         Team             @relation(fields: [teamId], references: [id])
  version      Int              @default(1)
  compilerPath String?
  status       SubmissionStatus @default(PENDING)
  submittedAt  DateTime         @default(now())
  testRuns     TestRun[]
  totalScore   Int              @default(0)
}

model TestRun {
  id               String          @id @default(cuid())
  submissionId     String
  submission       Submission      @relation(fields: [submissionId], references: [id])
  testCaseId       String
  status           TestRunStatus   @default(PENDING)
  compileSuccess   Boolean?
  compileTimeMs    Int?
  runSuccess       Boolean?
  runTimeMs        Int?
  actualStdout     String?
  actualStderr     String?
  expectedStdout   String?
  expectedExitCode Int?
  actualExitCode   Int?
  pointsEarned     Int             @default(0)
  bonusEarned      Int             @default(0)
  errorMessage     String?
  createdAt        DateTime        @default(now())
  completedAt      DateTime?

  @@index([submissionId])
  @@index([testCaseId])
}

enum SubmissionStatus {
  PENDING
  BUILDING
  READY
  EVALUATING
  COMPLETED
  FAILED
}

enum TestRunStatus {
  PENDING
  COMPILING
  RUNNING
  PASSED
  FAILED
  TIMEOUT
  ERROR
}
